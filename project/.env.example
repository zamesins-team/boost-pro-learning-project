# Порт, на котором PostgreSQL слушает на ХОСТЕ (его пробрасывает docker-compose).
# Если 5432 уже занят другим проектом — поменяйте здесь И в DATABASE_URL ниже.
DB_PORT=5432

# Строка подключения к PostgreSQL (Prisma). Порт должен совпадать с DB_PORT выше.
DATABASE_URL="postgresql://proservice:proservice@localhost:5432/proservice?schema=public"

# Пароль для входа в /admin.
# Это простой шлагбаум для учебного шаблона, а не полноценная авторизация.
ADMIN_PASSWORD="admin"
